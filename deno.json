{
  "name": "@tangent/opt",
  "version": "0.1.2",
  "exports": "./src/index.js",
  "publish": {
    "include": [
      "src/**/*.js",
      "README.md",
      "LICENSE",
      "THIRD_PARTY_NOTICES.md"
    ],
    "exclude": [
      "**/*.test.js",
      "**/*.spec.js"
    ]
  },
  "tasks": {
    "test": "deno test --allow-read",
    "lint": "deno lint src/",
    "fmt": "deno fmt src/"
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    },
    "exclude": [
      "dist/",
      "node_modules/",
      "coverage/"
    ]
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve",
    "exclude": [
      "dist/",
      "node_modules/",
      "coverage/"
    ]
  }
}
